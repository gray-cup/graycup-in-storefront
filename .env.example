# ─── App URL ──────────────────────────────────────────────────────────────────
# Used by better-auth for redirect URLs and CORS
NEXT_PUBLIC_APP_URL=http://localhost:6969

# ─── Database (Neon / any Postgres) ───────────────────────────────────────────
# Use the "pooled" connection string from Neon dashboard
# Format: postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=your_neon_database_url_here

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your_random_32_char_secret_here

# ─── Cashfree Payment Gateway ─────────────────────────────────────────────────
# Get credentials from https://merchant.cashfree.com/merchants/apiKeys
CASHFREE_CLIENT_ID=your_cashfree_client_id_here
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret_here
# Set to "sandbox" for test mode, "production" for live (default: production)
CASHFREE_MODE=production
# Also exposed to the browser for Cashfree JS SDK mode
NEXT_PUBLIC_CASHFREE_MODE=production

# ─── Cashfree Subscriptions ───────────────────────────────────────────────────
# Uses the same CASHFREE_CLIENT_ID / CASHFREE_CLIENT_SECRET / CASHFREE_MODE above.
# Requires Subscriptions to be enabled on your Cashfree merchant account
# (https://merchant.cashfree.com) — it's a separate product from Orders/Links.
# Webhook signature is verified with CASHFREE_CLIENT_SECRET (x-webhook-signature
# header), same as the one-off payment webhook — no extra secret needed.
# API version used for /plans and /subscriptions endpoints: 2025-01-01

# ─── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Get your site key from https://dash.cloudflare.com/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# IPInfo API Token (optional)
# Get your token from https://ipinfo.io/account/token
# Free tier: 50,000 requests/month (no token needed)
# Leave empty to use free tier without token
NEXT_PUBLIC_IPINFO_TOKEN=

# Location Override for Testing (optional)
# Set a country code to simulate being from that country
# Format: "US" or "US,New York,New York" (country,city,region)
# Examples: US, GB, DE, FR, SG, AE, AU, CA, JP
# Leave empty or unset for real IP-based detection

# ─── Supabase (legacy – for existing contact/quote/sample forms) ──────────────
# Get your credentials from https://supabase.com/dashboard/project/_/settings/api
#
# NEW KEYS (recommended): Use publishable/secret key format
# - Secret keys (sb_secret_...) are for server-side use only
# - Generate new keys in your Supabase dashboard under API Keys
#
# MIGRATION: The app supports both new and legacy keys during transition:
# - Set SUPABASE_SECRET_KEY for the new format
# - Legacy SUPABASE_SERVICE_ROLE_KEY still works but should be phased out
#
SUPABASE_URL=your_supabase_project_url
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Google Merchant Center (optional - for Content API integration)
# Get your credentials from https://merchants.google.com/
GOOGLE_MERCHANT_ID=your_merchant_id
# For Content API authentication, use a service account
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
